export const prerender = false;
---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { listRecentMedia } from '../../lib/server/db';
import { mediaObjectUrl } from '../../lib/server/storage';
import { pageUserOrNull } from '../../lib/server/guards';

const user = pageUserOrNull(Astro.locals);
const items = user ? await listRecentMedia(Astro.locals).catch(() => []) : [];
---

<BaseLayout title="Memories · Road Trip 2026" description="Private trip memories gallery." currentPath="/memories/">
  <section class="panel">
    <p class="eyebrow">Memories</p>
    <h1>Trip photos and videos, shared by the group.</h1>
    <p class="small-note">Private, invite-only trip media area.</p>
  </section>

  {!user ? (
    <section class="panel callout">
      <strong class="kicker">Sign in required</strong>
      <p>You need to sign in before viewing or uploading trip memories.</p>
      <div class="inline-actions">
        <a class="button" href="/memories/sign-in/">Sign in</a>
      </div>
    </section>
  ) : (
    <>
      <section class="panel">
        <p class="small-note">Signed in as {user.displayName}.</p>
        <div class="inline-actions">
          <a class="button" href="/memories/upload/">Open upload flow</a>
          {user.role === 'owner' ? <a class="button ghost" href="/memories/admin/">Admin</a> : null}
          <button class="button ghost" type="button" data-memory-logout>Sign out</button>
        </div>
      </section>

      <section class="panel">
        {items.length > 0 ? (
          <div class="memory-grid">
            {items.map((item: any) => {
              const imageUrl = item.type === 'image'
                ? mediaObjectUrl(item.storage_key_original, { width: 480, fit: 'cover' })
                : mediaObjectUrl(item.storage_key_thumbnail) ?? mediaObjectUrl(item.storage_key_preview) ?? mediaObjectUrl(item.storage_key_original);
              return (
                <a class="memory-card" href={`/memories/detail/?id=${encodeURIComponent(item.id)}`}>
                  {imageUrl ? (
                    <img src={imageUrl} alt={item.caption ?? 'Trip memory preview'} />
                  ) : (
                    <div class="memory-placeholder">{item.type}</div>
                  )}
                  <div class="memory-card-body">
                    <strong>{item.display_name}</strong>
                    <p>{item.caption ?? 'No caption yet.'}</p>
                    <p class="small-note">{item.trip_day ? `Day ${item.trip_day}` : 'Unassigned day'} · {item.comment_count} comments</p>
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <div class="callout">
            <strong class="kicker">No media yet</strong>
            <p>The gallery is ready. Once invited users sign in, they can upload photos and videos here.</p>
          </div>
        )}
      </section>
    </>
  )}

  <script src="/memories-nav.js" defer></script>
</BaseLayout>
