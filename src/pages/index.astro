---
import BaseLayout, { canonicalLabels } from '../layouts/BaseLayout.astro';
import DayCard from '../components/DayCard.astro';
import { days, routeLinks, trip } from '../data/trip.js';

const primaryNav = [
  { title: canonicalLabels.dailyPlans, href: '/days/', text: 'Open each drive day for route order, stop details, lodging, and charging notes.' },
  { title: canonicalLabels.chargingPlan, href: '/charging/', text: 'See the EV charging plan aligned with meals, breaks, and overnight stops.' },
  { title: canonicalLabels.mapLinks, href: '/map/', text: 'Jump into the full route or day-by-day links in Google Maps.' },
];
---

<BaseLayout title="Road Trip 2026" description="A Route 66-style Palm Springs to Chicago road trip guide with daily plans, charging, and route links." currentPath="/">
  <section class="home-hero panel">
    <div class="home-hero-grid">
      <div class="home-hero-copy">
        <p class="eyebrow">{trip.startDate}–{trip.endDate} · Palm Springs to Chicago</p>
        <p class="home-overline">Route 66 road trip guide</p>
        <h1>We're out to find our kicks on Route 66 — one unforgettable stop at a time.</h1>
        <p class="home-lede">One place for daily plans, charging plan flow, and map links from Palm Springs to Chicago.</p>
        <div class="hero-actions">
          <a class="button" href="/days/">Open {canonicalLabels.dailyPlans.toLowerCase()}</a>
          <a class="button ghost" href={routeLinks.fullTrip} target="_blank" rel="noreferrer">Open the full route in Google Maps</a>
        </div>
      </div>
    </div>
  </section>

  <section class="quick-grid panel home-nav-grid">
    <div class="home-style-intro">
      <p class="eyebrow">Start here</p>
      <h2>Jump into the part of the plan you need right now.</h2>
    </div>
    {primaryNav.map((item) => (
      <div>
        <strong>{item.title}</strong>
        <p>{item.text}</p>
        <a class="button ghost" href={item.href}>Open {item.title.toLowerCase()}</a>
      </div>
    ))}
  </section>

  <section class="panel">
    <p class="eyebrow">Trip at a glance</p>
    <div class="quick-grid">
      <div>
        <strong>{trip.startDate} to {trip.endDate}</strong>
        <p>5-day Route 66-style drive window with one overnight handoff per day.</p>
      </div>
      <div>
        <strong>Palm Springs → Chicago</strong>
        <p>West-to-midwest run with daily segments, stop highlights, and charging context.</p>
      </div>
      <div>
        <strong>{days.length} day segments</strong>
        <p>Open the full custom map page for complete interactive map links.</p>
      </div>
    </div>
    <div class="callout" style="margin-top: 1rem;">
      <strong class="kicker">Map preview</strong>
      <p>Need the complete route map module? Use the dedicated map page for the full interactive version and day-level handoff links.</p>
      <div class="hero-actions" style="margin-top: 0.85rem;">
        <a class="button" href="/map/">Open full map page</a>
      </div>
    </div>
  </section>

  <section>
    <div class="panel home-style-intro">
      <p class="eyebrow">Day-by-day route</p>
      <h2>Preview each day before you dive into full stop and charging detail.</h2>
    </div>
    <div class="day-grid">
      {days.map((day) => <DayCard day={day} />)}
    </div>
  </section>
</BaseLayout>
